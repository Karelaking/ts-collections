{
  "dependencies": {
    "path": "^0.12.7",
    "yaml": "^2.8.3",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.0.9",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "eslint": "^9.39.2",
    "prettier": "^3.7.4",
    "tinybench": "^6.0.0",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.16",
    "typescript": "^5.9.3",
    "ultracite": "7.7.0",
    "vitest": "^4.0.17"
  },
  "name": "ts-collections",
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "docs": "typedoc",
    "bench": "pnpm build && node bench/cli.mjs",
    "prepublishOnly": "pnpm build && pnpm test && pnpm lint",
    "publishConfig": "npm publish --access public",
    "clean": "rm -rf dist coverage",
    "type-check": "tsc --noEmit",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "type": "module",
  "version": "0.0.1",
  "description": "A fully-typed, Java-inspired Collections Framework for TypeScript, providing industry-grade implementations of Lists, Sets, Maps, Queues, and Iterators with strict type safety, predictable behavior, and performance transparency. Designed for education, large-scale applications, and library-level reuse, with clean abstractions, extensible contracts, and tree-shakable ESM builds",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "keywords": [
    "map",
    "set",
    "list",
    "queue",
    "library",
    "iterator",
    "framework",
    "algorithms",
    "typescript",
    "collections",
    "data-structures",
    "java-collections"
  ],
  "author": {
    "name": "Karel King",
    "email": "karelaking@example.com",
    "url": "https://github.com/Karelaking"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Karelaking/ts-collections.git"
  },
  "bugs": {
    "url": "https://github.com/Karelaking/ts-collections/issues"
  },
  "homepage": "https://github.com/Karelaking/ts-collections#readme",
  "packageManager": "pnpm@10.18.1",
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0",
    "pnpm": ">=8.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md"
  ],
  "license": "MIT"
}
